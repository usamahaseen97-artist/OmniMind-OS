# OmniMind — environment template (copy to .env.local / backend .env)
# Never commit real secrets.

# Frontend (Next.js)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8001
OMNIMIND_BACKEND_URL=http://127.0.0.1:8001

# Backend (FastAPI primary — port 8001)
MONGODB_URI=
REDIS_URL=

# AI providers (at least one for live completions)
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional services
CHANNEL_API_PORT=4001
CHANNEL_API_ORIGIN=http://localhost:3000
OMNIMIND_DOCKER_BUILD=0
