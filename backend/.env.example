# =============================================================================
# OmniMind V11 — backend/.env (copy to .env and fill values)
# Provider priority is automatic: first valid key in each chain wins.
# Inspect active routing: GET http://127.0.0.1:8001/api/v1/gateway/providers
# =============================================================================

# ── MongoDB Atlas (persistent chat + event_audit) ───────────────────────────
MONGODB_USER=your_atlas_db_user
MONGODB_PASSWORD=your-password-here
MONGODB_HOST=omnimind.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=omnimind
MONGODB_DB_NAME=omnimind
MONGODB_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
# MONGODB_URI=mongodb+srv://user:pass%40word@cluster.mongodb.net/

# ── Local LLM (LM Studio · port 1234) ───────────────────────────────────────
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_API_KEY=lm-studio
LOCAL_LLM_MODEL=meta-llama-3.1-8b-instruct
# gemini = fastest (like Google Gemini app). auto = Gemini first when GEMINI_API_KEY is set.
LLM_PROVIDER=gemini

# ── Chat / General Chatbot (priority: Gemini → Groq → OpenAI → LM Studio → Pollinations)
GEMINI_API_KEY=
# Standard chat + agents model (gemini-1.5-flash or gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-flash
# AGENT_GEMINI_MODEL=gemini-1.5-pro
# Google embeddings for RAG / vector_memory (no OPENAI_API_KEY needed)
# Prefer text-embedding-004; auto-falls back to gemini-embedding-001 if unavailable on your key
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
MONGODB_EMBEDDING_MODEL=models/text-embedding-004
TAVILY_API_KEY=
# Optional — real OpenAI cloud only; not required when GEMINI_API_KEY is set
OPENAI_API_KEY=
# Groq API (key starts with gsk_) — used for fast chat fallback
GROK_API_KEY=

# OpenRouter (HUNYUAN_API_KEY alias) — multi-model chat
HUNYUAN_API_KEY=
OPENROUTER_API_KEY=
POLLINATIONS_API_KEY=
POLLINATIONS_SECRET_KEY=
POLLINATIONS_CHAT_MODEL=openai-fast

# ── Image generation (priority: Replicate Flux → Stability → Pollinations Pro → free)
REPLICATE_API_TOKEN=
STABILITY_API_KEY=
HUGGINGFACE_API_KEY=

# ── Creative Video (priority: Replicate I2V → WAN → Pollinations Seedance → Ken-Burns)
WAN_API_KEY=
# REPLICATE_API_TOKEN=  (shared with image)

# ── Research & maps ─────────────────────────────────────────────────────────
TAVILY_API_KEY=
GOOGLE_MAPS_API_KEY=

# ── OmniMusic chatbot tool (Spotify metadata + YouTube audio via yt-dlp) ───
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Fast music: Audius first (seconds). Set MUSIC_SKIP_YTDLP=false for chatbot YouTube fallback (slow).
MUSIC_SKIP_YTDLP=true
# Dynamic Global Search: YouTube top-5 when ES/local has <3 hits (independent of MUSIC_SKIP_YTDLP).
MUSIC_GLOBAL_SEARCH_YTDLP=true
MUSIC_USE_GEMINI_TOOL=false
MUSIC_YTDLP_TIMEOUT_SECONDS=18

# ── Elasticsearch (fast play_music + OmniMusic search) ─────────────────────
# If ES service is down / port 9200 locked, API auto-falls back to backend/data/songs_static.json
ELASTICSEARCH_URL=https://localhost:9200
ELASTICSEARCH_ENABLED=true
# Set false for instant static-only search (no ES connection attempts):
# ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_SONGS_INDEX=songs
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elastic_password_here
ELASTICSEARCH_VERIFY_SSL=false
# Start: docker compose up -d elasticsearch
# Seed index: POST http://127.0.0.1:8001/api/v1/music/es/reindex

# ── OmniMovies (TMDB international catalog) ────────────────────────────────
TMDB_API_KEY=
KAFKA_MOVIE_ANALYTICS_TOPIC=movie-analytics
KAFKA_MOVIE_EVENTS_TOPIC=movie-events
KAFKA_MUSIC_EVENTS_TOPIC=music-events
KAFKA_TV_EVENTS_TOPIC=tv-events

# ── Optional CLI paths (Windows: set if not on PATH) ───────────────────────
# DOCKER_BINARY=C:\Program Files\Docker\Docker\resources\bin\docker.exe
# FFMPEG_BINARY=

# ── Streaming infra (optional · lazy by default) ───────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENTERTAINMENT_TOPIC=omnimind.entertainment
STREAMING_LAZY_LOAD=true
SPARK_MASTER_URL=spark://localhost:7077
SPARK_UI_URL=http://localhost:8080

# ── Supabase (optional) ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── n8n workflow orchestration (self-hosted) ───────────────────────────────
N8N_ENABLED=true
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_TIMEOUT_SECONDS=30
N8N_WEBHOOK_DEPLOY_STAGING=/webhook/deploy-staging
N8N_WEBHOOK_TRADING_ALERT=/webhook/trading-alert
N8N_WEBHOOK_NOTIFICATIONS=/webhook/notifications

# ── Security ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
OMNIMIND_PUBLIC_API_URL=http://127.0.0.1:8001
RATE_LIMIT=30/minute

# ── JWT (production auth · PyJWT + bcrypt) ───────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=14
# Set true to require Bearer tokens on JWT_PROTECTED_PREFIX routes
JWT_ENFORCE_MIDDLEWARE=false
JWT_PROTECTED_PREFIX=/api/v1/admin
OMNIMIND_BOOTSTRAP_EMAIL=admin@omnimind.local
OMNIMIND_BOOTSTRAP_PASSWORD=changeme-in-production
# Or pre-hash: OMNIMIND_BOOTSTRAP_PASSWORD_HASH=$2b$12$...

# Cross-platform sovereign session (/api/v1/auth/session)
OMNIMIND_SOVEREIGN_USERNAME=
OMNIMIND_SOVEREIGN_PASSWORD=

# Device operator session (/api/v1/auth/session-token)
OMNIMIND_OPERATOR_USERNAME=
OMNIMIND_OPERATOR_SECRET_KEY=

# ── Redis cache (MongoDB read-through · memory fallback when down) ─────────
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0?protocol=2
REDIS_DEFAULT_TTL_SECONDS=300
REDIS_CONNECT_TIMEOUT_SECONDS=3

# ── Webhook ingestion (n8n / Make.com HMAC verification) ───────────────────
WEBHOOK_SIGNING_SECRET=
# Falls back to N8N_API_KEY for /api/v1/webhooks/ingest/n8n when unset

# ── Tool → provider map (reference) ─────────────────────────────────────────
# chat          → lm_studio | gemini | openai_cloud | grok | pollinations_*
# create_image  → replicate_flux | stability | pollinations_hd | pollinations_free
# video         → replicate_i2v | wan | pollinations_video | ken_burns
# deep_research → tavily | gemini_research | sandbox
# maps          → tavily_maps | gemini_maps | sandbox
