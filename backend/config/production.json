{
  "environment": "production",
  "api": {
    "host": "0.0.0.0",
    "port": 8001,
    "workers": 4,
    "public_url": "https://api.omnimind.app"
  },
  "cors": {
    "allowed_origins": [
      "https://app.omnimind.app",
      "https://omnimind.app",
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "capacitor://localhost",
      "ionic://localhost",
      "http://localhost",
      "https://localhost"
    ],
    "allow_credentials": true,
    "allow_methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
    "allow_headers": ["Authorization", "Content-Type", "X-Request-Id", "X-OmniMind-Client"]
  },
  "jwt": {
    "algorithm": "HS256",
    "access_expire_minutes": 60,
    "refresh_expire_days": 14,
    "require_on_paths_prefix": "/api/v1/admin"
  },
  "redis": {
    "enabled": true,
    "url": "redis://redis:6379/0",
    "default_ttl_seconds": 300,
    "connect_timeout_seconds": 3
  },
  "webhooks": {
    "signature_header_n8n": "X-N8N-Signature",
    "signature_header_make": "X-Make-Signature",
    "signature_header_generic": "X-OmniMind-Signature",
    "replay_cache_ttl_seconds": 86400
  },
  "mongodb": {
    "prefer_cache_for_reads": true,
    "cache_namespace": "omni:prod"
  },
  "mobile_shells": {
    "ios_webview_origins": ["capacitor://localhost", "ionic://localhost"],
    "android_webview_origins": ["http://localhost", "https://localhost", "file://"]
  }
}
