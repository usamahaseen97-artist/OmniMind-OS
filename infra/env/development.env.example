# OmniMind — Development environment
# Copy: cp infra/env/development.env.example backend/.env

OMNIMIND_ENV=development
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET_KEY=dev-only-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
OMNIMIND_PUBLIC_API_URL=http://127.0.0.1:8001
STREAMING_LAZY_LOAD=true
ELASTICSEARCH_ENABLED=false
