# OmniMind — Production environment
# NEVER commit real secrets. Use K8s Secrets / AWS Secrets Manager / Vault.

OMNIMIND_ENV=production
REDIS_ENABLED=true
REDIS_HOST=omnimind-cache
REDIS_PORT=6379
JWT_SECRET_KEY=${JWT_SECRET_KEY}
ALLOWED_ORIGINS=https://app.omnimind.app,https://omnimind.app
OMNIMIND_PUBLIC_API_URL=https://api.omnimind.app
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
CDN_BASE_URL=https://cdn.omnimind.app
S3_BUCKET=omnimind-prod-assets
S3_REGION=us-east-1
JWT_ENFORCE_MIDDLEWARE=true
UVICORN_WORKERS=4
WEBHOOK_SIGNING_SECRET=${WEBHOOK_SIGNING_SECRET}
