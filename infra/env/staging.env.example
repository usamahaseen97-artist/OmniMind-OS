# OmniMind — Staging environment

OMNIMIND_ENV=staging
REDIS_ENABLED=true
REDIS_HOST=omnimind-cache
REDIS_PORT=6379
JWT_SECRET_KEY=${JWT_SECRET_KEY}
ALLOWED_ORIGINS=https://staging.omnimind.app
OMNIMIND_PUBLIC_API_URL=https://api-staging.omnimind.app
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
CDN_BASE_URL=https://cdn-staging.omnimind.app
S3_BUCKET=omnimind-staging-assets
S3_REGION=us-east-1
UVICORN_WORKERS=2
