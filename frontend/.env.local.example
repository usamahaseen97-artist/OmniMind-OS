# Copy to .env.local — backend on port 8001 (see run-backend-8001.ps1)
NEXT_PUBLIC_USE_API_PROXY=false
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8001
OMNIMIND_BACKEND_URL=http://127.0.0.1:8001

# OmniForge gateway + terminal (docker-compose.omniforge.yml)
NEXT_PUBLIC_OMNIFORGE_API_URL=http://localhost:8080
NEXT_PUBLIC_OMNIFORGE_TERMINAL_WS_URL=ws://localhost:8091/ws/terminal

LLM_PROVIDER=lm_studio
LM_STUDIO_URL=http://127.0.0.1:1234/v1
# OPENAI_API_KEY (sk-lm-*) — set in backend/.env only, not NEXT_PUBLIC_
OMNIMIND_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
OMNIMIND_API_TOKEN=replace-with-a-long-random-token
NEWS_API_KEY=replace-with-your-newsapi-key

# OmniTV event streaming (telemetry only — NOT video; video stays on YouTube/HLS).
# Leave OMNITV_KAFKA_BROKERS empty to use the zero-infra in-memory bus.
# To enable real Apache Kafka: run `npm install kafkajs`, start a broker, then set:
# OMNITV_KAFKA_BROKERS=localhost:9092
OMNITV_KAFKA_BROKERS=
OMNITV_KAFKA_TOPIC=omnitv.events
OMNITV_KAFKA_CLIENT_ID=omnitv-app
OMNITV_KAFKA_GROUP_ID=omnitv-app

# OmniStream — Jellyfin (open-source media server) for your own movie/series library.
# Leave JELLYFIN_URL empty to use the built-in demo catalog.
# Get an API key from Jellyfin Dashboard → Advanced → API Keys.
# The key stays server-side; the browser only talks to /api/omnistream/*.
JELLYFIN_URL=
JELLYFIN_API_KEY=
# Optional — auto-detected from /Users if left blank.
JELLYFIN_USER_ID=
