{
  "name": "omnimind-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3000",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev:channels": "node server/channel-api.js",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify": "npm run lint && npm run test && npm run verify:contracts && npm run build",
    "verify:contracts": "tsx scripts/verify-contracts.ts",
    "omnimind": "tsx sdk/node/cli/index.ts",
    "sdk:doctor": "tsx sdk/node/cli/index.ts doctor",
    "sdk:create": "tsx sdk/node/cli/index.ts create"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.24",
    "@vitejs/plugin-react": "^5.0.4",
    "animejs": "^4.4.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "hls.js": "^1.6.16",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.5.16",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "react-rnd": "^10.5.3",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "yt-channel-info": "^3.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.2.6"
  }
}
